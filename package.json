{
  "name": "web-template",
  "version": "0.0.1",
  "description": "web template project",
  "type": "module",
  "scripts": {
    "dev": "APP_ENV=development node --experimental-strip-types --experimental-vm-modules scripts/start.ts",
    "build": "rsbuild build --config ./scripts/rsbuild.config.ts",
    "commitlint": "commitlint --config ./eng/.commitlintrc.json --edit",
    "cspell": "cspell --config ./eng/cspell.config.json --quiet .",
    "eslint": "eslint --config ./eng/eslint.config.js .",
    "lint": "npm run cspell && npm run eslint",
    "lint:staged": "lint-staged --config ./eng/.lintstagedrc.json",
    "postinstall": "husky || true",
    "prepreview": "npm run build",
    "preview": "APP_ENV=development node lib/main.js",
    "type-check": "rm -rf ./node_modules/.cache/tsbuild && vue-tsc --build ./tsconfig.json"
  },
  "author": "Dunn",
  "license": "MIT",
  "dependencies": {
    "@fastify/deepmerge": "^3.2.1",
    "@fastify/static": "^9.0.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/platform-fastify": "^11.1.14",
    "@sequelize/core": "^7.0.0-alpha.48",
    "@sequelize/sqlite3": "^7.0.0-alpha.48",
    "reka-ui": "^2.8.2",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@camaro/eslint-config": "^0.1.4",
    "@camaro/tsconfig": "^1.3.0",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@rsbuild/core": "^2.0.0-beta.6",
    "@rsbuild/plugin-vue": "^1.2.6",
    "@types/node": "^24.0.4",
    "@unocss/postcss": "^66.6.2",
    "@vue/eslint-config-typescript": "^14.7.0",
    "cspell": "^9.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "type-fest": "^5.4.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "unocss": "^66.6.2",
    "vue-tsc": "^3.2.5"
  }
}
