{
  "name": "vue-nestjs-ssr-starter",
  "version": "0.0.1",
  "description": "A lightweight full-stack SSR starter with Vue 3, NestJS, Fastify, PrimeVue, and Rsbuild.",
  "type": "module",
  "scripts": {
    "dev": "APP_ENV=development node --experimental-strip-types --experimental-vm-modules scripts/start.ts",
    "build": "rsbuild build --config ./scripts/rsbuild.config.ts",
    "commitlint": "commitlint --config ./eng/.commitlintrc.json --edit",
    "cspell": "cspell --config ./eng/cspell.config.json --quiet .",
    "eslint": "eslint --config ./eng/eslint.config.js .",
    "lint": "npm run cspell && npm run eslint",
    "lint:staged": "lint-staged --config ./eng/.lintstagedrc.json",
    "postinstall": "husky || true",
    "prepreview": "npm run build",
    "preview": "APP_ENV=development node lib/main.js",
    "type-check": "rm -rf ./node_modules/.cache/tsbuild && vue-tsc --build ./tsconfig.json"
  },
  "author": "Dunn",
  "license": "MIT",
  "dependencies": {
    "@css-render/vue3-ssr": "^0.15.14",
    "@fastify/static": "^9.0.0",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-fastify": "^11.1.16",
    "@primeuix/themes": "^2.0.3",
    "@sequelize/core": "^7.0.0-alpha.48",
    "@sequelize/sqlite3": "^7.0.0-alpha.48",
    "deepmerge": "^4.3.1",
    "nestjs-zod": "^5.1.1",
    "primevue": "^4.5.4",
    "rxjs": "^7.8.2",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@camaro/eslint-config": "^0.2.0",
    "@camaro/tsconfig": "^1.3.0",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@primevue/auto-import-resolver": "^4.5.4",
    "@rsbuild/core": "^2.0.0-beta.8",
    "@rsbuild/plugin-vue": "^1.2.7",
    "@types/node": "^24.11.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "cspell": "^9.7.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "type-fest": "^5.4.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "unplugin-vue-components": "^31.0.0",
    "vue-tsc": "^3.2.5"
  }
}
